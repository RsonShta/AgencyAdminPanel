# .gitignore for Python backend

# Virtual environments
venv/
env/
.venv/
.env/

# Python caches and compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/
*.egg
*.whl

# Test and coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Type checkers / caches
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Logs
*.log
logs/
debug.log

# Environment / secrets
.env
*.env
.env.*
secrets.json

# Database files
*.db
*.sqlite3
*.sqlite
instance/

# Celery
celerybeat-schedule

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Notebook checkpoints
.ipynb_checkpoints/

# Misc
.webassets-cache/
.coverage.*

# Ignore pipenv/poetry lock files if you store them elsewhere
Pipfile.lock
poetry.lock
